            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{host_url}}/emergency-needs/public/active",
              "host": [
                "{{host_url}}"
              ],
              "path": [
                "emergency-needs",
                "public",
                "active"
              ]
            },
            "description": "Same payload as /emergency-needs (defaults to isResolved=false). Cached 5 min."
          }
        },
        {
          "name": "Get emergency need by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{host_url}}/emergency-needs/{{needId}}",
              "host": [
                "{{host_url}}"
              ],
              "path": [
                "emergency-needs",
                "{{needId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update emergency need",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated: tripled the requested quantity\",\n  \"category\": \"first_aid\"\n}"
            },
            "url": {
              "raw": "{{host_url}}/emergency-needs/{{needId}}",
              "host": [
                "{{host_url}}"
              ],
              "path": [
                "emergency-needs",
                "{{needId}}"
              ]
            }
          }
        },
        {
          "name": "Resolve emergency need (mark as covered)",
          "request": {
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{host_url}}/emergency-needs/{{needId}}/resolve",
              "host": [
                "{{host_url}}"
              ],
              "path": [
                "emergency-needs",
                "{{needId}}",
                "resolve"
              ]
            },
            "description": "Sets isResolved=true. The need will disappear from the default list."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200)); const b = pm.response.json(); pm.expect(b.data.isResolved).to.eql(true);"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete emergency need",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{host_url}}/emergency-needs/{{needId}}",
              "host": [
                "{{host_url}}"
              ],
              "path": [
                "emergency-needs",
                "{{needId}}"
              ]
            }
          }
        }
      ]
    }
