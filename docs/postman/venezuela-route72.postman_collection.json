              "raw": "{\n  \"licensePlate\": \"{{licensePlate}}\",\n  \"driverName\": \"Juan Pérez\",\n  \"driverPhone\": \"+584141112222\",\n  \"origin\": \"{{supplyCenterId}}\",\n  \"originName\": \"Centro de Acopio Caracas\",\n  \"destination\": {\n    \"state\": \"Miranda\",\n    \"city\": \"Guarenas\",\n    \"parish\": \"Plaza\",\n    \"specificLocation\": \"Urb. Trapichito, calle 3, casa 45\"\n  },\n  \"loadedItems\": [\n    {\n      \"itemName\": \"Arroz blanco 1kg\",\n      \"quantity\": 10,\n      \"unit\": \"kg\"\n    },\n    {\n      \"itemName\": \"Agua potable 1L\",\n      \"quantity\": 20,\n      \"unit\": \"liters\"\n    }\n  ],\n  \"emptyPhotoBase64\": \"UklGRiQAAABXRUJQVlA4IBgAAAAwAQCdASoBAAEAAwA0JaQAA3AA/vuUAAA=\"\n}"
            },
            "url": {
              "raw": "{{host_url}}/dispatches",
              "host": [
                "{{host_url}}"
              ],
              "path": [
                "dispatches"
              ]
            },
            "description": "Persists dispatch atomically (decrements stock) and enqueues emptyPhotoBase64 for the worker to decode into /app/storage/carriers/<plate>/<uuid>.webp. Use a ~70-byte PNG placeholder for tests; in prod use a 12–15 KB WebP."
          },
